{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataNexa",
  "version": "0.1.2",
  "identifier": "com.mingo.datanexa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DataNexa",
        "width": 1180,
        "height": 760,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Mingo Technology",
    "copyright": "(C) 2026 Zachary Wu All Rights Reserved",
    "category": "DeveloperTool"
  }
}
